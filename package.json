{
  "name": "kielcloak",
  "version": "1.0.0",
  "type": "module",
  "description": " 'KielCloak' Backend für Anwendung",
  "main": "index.ts",
  "scripts": {
    "test": "cross-env NODE_ENV=test vitest run --config vitest.config.ts",
    "test:watch": "cross-env NODE_ENV=test vitest --config vitest.config.ts",
    "test:integration": "cross-env NODE_ENV=test vitest run --config vitest.integration.config.ts",
    "dev": "node --loader ts-node/esm src/index.ts",
    "build": "webpack",
    "start": "webpack serve --open",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@inrupt/solid-client": "^3.0.0",
    "@inrupt/solid-client-authn-browser": "^3.1.1",
    "@inrupt/solid-client-authn-node": "^3.1.1",
    "@inrupt/vocab-common-rdf": "^1.0.5",
    "@inrupt/vocab-solid": "^1.0.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.0",
    "@eslint/js": "^9.36.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^22.19.0",
    "@types/supertest": "^6.0.3",
    "@vitest/ui": "^4.0.15",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.2",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.12.4",
    "jsdom": "^27.2.0",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "style-loader": "^4.0.0",
    "supertest": "^6.3.3",
    "testcontainers": "^11.11.0",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.44.1",
    "vitest": "^4.0.15",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2",
    "webpack-node-externals": "^3.0.0"
  }
