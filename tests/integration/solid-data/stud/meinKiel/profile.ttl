@prefix : <http://localhost:3000/stud/meinKiel/profile#>.
@prefix schema: <http://schema.org/>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix fibo-fbc-pas-caa: <https://spec.edmcouncil.org/fibo/ontology/FBC/ProductsAndServices/ClientsAndAccounts/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix aiiso: <https://vocab.org/aiiso#>.
@prefix org: <https://www.w3.org/ns/org#>.

:me
  a schema:Person;
    schema:name "Petra Plietsch"^^xsd:string;
    schema:address :address;
    owl:sameAs :stud;
    schema:accountId "stud".

:stud
  a schema:Person;
    schema:identifier "9660876"^^xsd:string;
    org:memberOf :uni;
    owl:sameAs :me.

:address
  a schema:PostalAddress;
    schema:streetAddress "Musterstraße 1"^^xsd:string;
    schema:addressLocality "Kiel"^^xsd:string;
    schema:postalCode "24103"^^xsd:string;
    schema:addressCountry "DE"^^xsd:string;
    schema:identifier "MG-2025-0456"^^xsd:string;
    schema:startDate "2025-09-01"^^xsd:date;
    owl:sameAs <http://localhost:3000/lord/addresses/musterstrasse1>.

:bankAccount
  a fibo-fbc-pas-caa:Account;
    fibo-fbc-pas-caa:AccountHolder :me;
    fibo-fbc-pas-caa:AccountProvider "Förde Sparkasse"^^xsd:string;
    fibo-fbc-pas-caa:AccountIdentifier "DE12345678900000000000"^^xsd:string.
  
:uni
  a aiiso:Organization;
    schema:name "Christian-Albrecht-Universität zu Kiel"^^xsd:string.
