@prefix acl: <http://www.w3.org/ns/auth/acl#>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.

# MailBox: Allow Vermieter (lord) and Kielcloak (my-app) read & write access
<#mailbox-access>
    a acl:Authorization;
    acl:accessTo <./>;
    acl:default <./>;
    acl:agent <http://localhost:3000/kielcloak/profile/card#me>;
    acl:mode acl:Read, acl:Write.

# Owner (vermieter/lord) full control
<#owner>
    a acl:Authorization;
    acl:agent <http://localhost:3000/lord/profile/card#me>;
    acl:accessTo <./>;
    acl:default <./>;
    acl:mode acl:Read, acl:Write, acl:Control.

